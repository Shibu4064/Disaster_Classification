els_1 + labels_2, loc=\"best\")\nax1.set_title(\"Training History\")\nfig.tight_layout()\nfig.savefig(FIG_DIR / \"06_training_history.png\", dpi=200, bbox_inches=\"tight\")\nplt.show()\n\n# 2) Per-label AP and F1 bar chart\nplot_df = per_label_df.copy()\nplot_df[\"short_label\"] = plot_df[\"label\"].str.replace(\"_any\", \"\", regex=False).str.replace(\"_\", \" \", regex=False)\nplot_df = plot_df.sort_values(\"ap\", ascending=True)\n\nx = np.arange(len(plot_df))\nwidth = 0.38\nfig, ax = plt.subplots(figsize=(11, 6))\nax.barh(x - width / 2, plot_df[\"ap\"], height=width, label=\"AP\")\nax.barh(x + width / 2, plot_df[\"f1\"], height=width, label=\"F1\")\nax.set_yticks(x)\nax.set_yticklabels(plot_df[\"short_label\"])\nax.set_xlabel(\"Score\")\nax.set_xlim(0, 1.0)\nax.set_title(\"Per-label Test Performance\")\nax.grid(axis=\"x\", alpha=0.3)\nax.legend()\nfig.tight_layout()\nfig.savefig(FIG_DIR / \"07_per_label_ap_f1.png\", dpi=200, bbox_inches=\"tight\")\nplt.show()\n\n# 3) Validation-tuned threshold per label\nthr_df = per_label_df.sort_values(\"threshold\", ascending=True)\nfig, ax = plt.subplots(figsize=(10, 5))\nax.barh(thr_df[\"label\"].str.replace(\"_\", \" \", regex=False), thr_df[\"threshold\"])\nax.set_xlabel(\"Decision threshold\")\nax.set_xlim(0, 1.0)\nax.set_title(\"Validation-tuned Thresholds Used for Test Evaluation\")\nax.grid(axis=\"x\", alpha=0.3)\nfig.tight_layout()\nfig.savefig(FIG_DIR / \"08_tuned_thresholds.png\", dpi=200, bbox_inches=\"tight\")\nplt.show()\n\n# 4) Compact overall metrics bar chart\nwith open(OUTPUT_DIR / \"test_metrics.json\", \"r\") as f:\n    saved_test_metrics = json.load(f)\noverall_metric_names = [\"macro_ap\", \"micro_ap\", \"macro_f1\", \"micro_f1\"]\noverall_metric_values = [saved_test_metrics.get(k, np.nan) for k in overall_metric_names]\nfig, ax = plt.subplots(figsize=(7, 4))\nax.bar([k.replace(\"_\", \" \").upper() for k in overall_metric_names], overall_metric_values)\nax.set_ylim(0, 1.0)\nax.set_ylabel(\"Score\")\nax.set_title(\"Overall Test Metrics\")\nax.grid(axis=\"y\", alpha=0.3)\nfig.tight_layout()\nfig.savefig(FIG_DIR / \"09_overall_test_metrics.png\", dpi=200, bbox_inches=\"tight\")\nplt.show()\n\nprint(\"Saved final result plots to:\", FIG_DIR)\nprint(sorted([p.name for p in FIG_DIR.glob(\"*.png\")]))\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T15:04:50.428548Z","iopub.execute_input":"2026-05-20T15:04:50.429159Z","iopub.status.idle":"2026-05-20T15:04:52.703563Z","shell.execute_reply.started":"2026-05-20T15:04:50.429130Z","shell.execute_reply":"2026-05-20T15:04:52.702930Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x500 with 2 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 1100x600 with 1 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x500 with 1 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"<Figure size 700x400 with 1 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved final result plots to: /kaggle/working/ladi_final_streaming_runs/static_gcn_efficientnet_b0_streaming_full_seed42/figures\n['01_label_prevalence.png', '02_label_cooccurrence_heatmap.png', '03_pmi_graph_heatmap.png', '04_pmi_graph_network.png', '05_static_gcn_architecture.png', '06_training_history.png', '07_per_label_ap_f1.png', '08_tuned_thresholds.png', '09_overall_test_metrics.png']\n","output_type":"stream"}],"execution_count":25},{"id":"de87afeb-a94c-468b-98c4-f1e5b1621eff","cell_type":"code","source":"\n# ============================================================\n# 12B. Visual Inference Examples from Test Stream\n# ============================================================\n# This cell streams a few test images, runs the trained model, and displays true vs predicted labels.\n\nNUM_INFERENCE_EXAMPLES = 6\nCONFIDENCE_DISPLAY_THRESHOLD = 0.30  # show top probabilities above this value; binary decisions still use tuned thresholds\n\nmodel.eval()\nexamples = []\n\nfor idx, sample in enumerate(stream_ds[\"test\"]):\n    if len(examples) >= NUM_INFERENCE_EXAMPLES:\n        break\n    try:\n        img = get_image_from_sample(sample)\n        y_true_vec = get_label_vector(sample, LABEL_NAMES).astype(int)\n        x = val_transform(img).unsqueeze(0).to(DEVICE)\n        with torch.no_grad():\n            with torch.amp.autocast(\"cuda\", enabled=(USE_AMP and DEVICE.type == \"cuda\")):\n                prob = torch.sigmoid(model(x)).detach().cpu().numpy()[0]\n        y_pred_vec = (prob >= best_thresholds).astype(int)\n        sid = get_sample_id(sample, idx)\n        examples.append((sid, img, y_true_vec, prob, y_pred_vec))\n    except Exception:\n        continue\n\nif len(examples) == 0:\n    print(\"No inference examples could be loaded from the test stream.\")\nelse:\n    cols = 3\n    rows = int(math.ceil(len(examples) / cols))\n    fig, axes = plt.subplots(rows, cols, figsize=(15, 5 * rows))\n    axes = np.array(axes).reshape(-1)\n    \n    for ax, (sid, img, y_true_vec, prob, y_pred_vec) in zip(axes, examples):\n        ax.imshow(img)\n        true_labels = [LABEL_NAMES[i].replace(\"_\", \" \") for i, v in enumerate(y_true_vec) if v == 1]\n        pred_labels = [f\"{LABEL_NAMES[i].replace('_', ' ')} ({prob[i]:.2f})\" for i, v in enumerate(y_pred_vec) if v == 1]\n        if len(pred_labels) == 0:\n            top_idx = np.argsort(prob)[-3:][::-1]\n            pred_labels = [f\"{LABEL_NAMES[i].replace('_', ' ')} ({prob[i]:.2f})\" for i in top_idx]\n        title = \"ID: \" + str(sid)[:28] + \"\\n\"\n        title += \"True: \" + (\", \".join(true_labels[:4]) if true_labels else \"None\") + \"\\n\"\n        title += \"Pred: \" + (\", \".join(pred_labels[:4]) if pred_labels else \"None\")\n        ax.set_title(\"\\n\".join(textwrap.wrap(title, width=48)), fontsize=9)\n        ax.axis(\"off\")\n    \n    for ax in axes[len(examples):]:\n        ax.axis(\"off\")\n    \n    fig.suptitle(\"Static GCN EfficientNet-B0: Test Inference Examples\", fontsize=14)\n    fig.tight_layout()\n    fig.savefig(FIG_DIR / \"10_inference_examples.png\", dpi=200, bbox_inches=\"tight\")\n    plt.show()\n    print(\"Saved visual inference examples to:\", FIG_DIR / \"10_inference_examples.png\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T15:05:07.850334Z","iopub.execute_input":"2026-05-20T15:05:07.851043Z","iopub.status.idle":"2026-05-20T15:05:14.069165Z","shell.execute_reply.started":"2026-05-20T15:05:07.851014Z","shell.execute_reply":"2026-05-20T15:05:14.068323Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1500x1000 with 6 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved visual inference examples to: /kaggle/working/ladi_final_streaming_runs/static_gcn_efficientnet_b0_streaming_full_seed42/figures/10_inference_examples.png\n","output_type":"stream"}],"execution_count":26},{"id":"0995b89b","cell_type":"markdown","source":"## Notebook Completion Notes\n\nThis notebook is fixed to:\n\n```python\nRUN_MODEL = \"static_gcn_efficientnet_b0\"\n```\n\nOutputs are saved under:\n\n```text\n/kaggle/working/ladi_final_streaming_runs/static_gcn_efficientnet_b0_streaming_full_seed42/\n```\n\nFor a smoke test, use small limits in the configuration cell:\n\n```python\nTRAIN_LIMIT = 512\nVAL_LIMIT = 128\nTEST_LIMIT = 128\nNUM_EPOCHS = 2\nLABEL_SCAN_LIMIT = 1000\n```\n\nFor a final streaming run, use:\n\n```python\nTRAIN_LIMIT = None\nVAL_LIMIT = None\nTEST_LIMIT = None\nLABEL_SCAN_LIMIT = None\n```\n\nIf you face GPU memory issues on P100, reduce:\n\n```python\nBATCH_SIZE = 8\nIMAGE_SIZE = 288\n```\n","metadata":{}}]}