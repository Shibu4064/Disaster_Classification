e_heatmap.png\", dpi=200, bbox_inches=\"tight\")\nplt.show()\n\n# 3) Normalised PMI adjacency heatmap used by Static GCN\nfig, ax = plt.subplots(figsize=(9, 8))\nim = ax.imshow(A_PMI)\nax.set_title(\"Normalised PMI Adjacency Matrix Used by Static GCN\")\nax.set_xticks(range(NUM_LABELS))\nax.set_yticks(range(NUM_LABELS))\nax.set_xticklabels(LABEL_NAMES, rotation=45, ha=\"right\")\nax.set_yticklabels(LABEL_NAMES)\nfig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)\nfig.tight_layout()\nfig.savefig(FIG_DIR / \"03_pmi_graph_heatmap.png\", dpi=200, bbox_inches=\"tight\")\nplt.show()\n\n# 4) Simple circular graph illustration of the strongest PMI connections\nA_vis = A_PMI.copy()\nnp.fill_diagonal(A_vis, 0.0)\nedge_threshold = np.percentile(A_vis[A_vis > 0], 65) if np.any(A_vis > 0) else 1.0\nangles = np.linspace(0, 2 * np.pi, NUM_LABELS, endpoint=False)\ncoords = np.stack([np.cos(angles), np.sin(angles)], axis=1)\n\nfig, ax = plt.subplots(figsize=(9, 9))\nax.set_title(\"PMI Label Graph: Stronger Training Co-occurrence Links\")\n\n# draw edges\nmax_w = A_vis.max() if A_vis.max() > 0 else 1.0\nfor i in range(NUM_LABELS):\n    for j in range(i + 1, NUM_LABELS):\n        w = A_vis[i, j]\n        if w >= edge_threshold and w > 0:\n            ax.plot([coords[i, 0], coords[j, 0]], [coords[i, 1], coords[j, 1]],\n                    linewidth=0.7 + 4.0 * (w / max_w), alpha=0.45)\n\n# draw nodes and labels\nax.scatter(coords[:, 0], coords[:, 1], s=650, zorder=3)\nfor i, name in enumerate(LABEL_NAMES):\n    short_name = name.replace(\"_any\", \"\").replace(\"_or_greater\", \"+\").replace(\"_\", \" \")\n    wrapped = \"\\n\".join(textwrap.wrap(short_name, width=14))\n    ax.text(coords[i, 0] * 1.22, coords[i, 1] * 1.22, wrapped,\n            ha=\"center\", va=\"center\", fontsize=9)\nax.axis(\"off\")\nfig.tight_layout()\nfig.savefig(FIG_DIR / \"04_pmi_graph_network.png\", dpi=200, bbox_inches=\"tight\")\nplt.show()\n\nprint(\"Saved graph and dataset visualisations to:\", FIG_DIR)\npr